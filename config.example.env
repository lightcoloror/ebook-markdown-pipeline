# Graphic-Text Material Converter example environment.
# Copy this file to .env or load selected variables in your shell.
# Do not commit real API tokens or machine-specific private paths.

# Optional HTTP/API settings. The default local Web/API port is defined in
# config/http.env; use these only when you intentionally override it.
# EBOOK_CONVERTER_HTTP_HOST=127.0.0.1
# EBOOK_CONVERTER_HTTP_PORT=9241
# EBOOK_CONVERTER_DOCKER_HTTP_HOST=0.0.0.0
# EBOOK_CONVERTER_API_TOKEN=replace-with-a-local-token

# Optional local tool/model cache directory.
# If unset, wrappers use a user-level cache or the repository-adjacent tools/
# directory when appropriate.
# EBOOK_CONVERTER_TOOL_CACHE=C:\path\to\ebook-converter-tools

# Optional Umi-OCR configuration for scanned PDFs and images.
# Set the root directory if your Umi-OCR package contains Umi-OCR.exe and
# UmiOCR-data\plugins\win7_x64_PaddleOCR-json.
# EBOOK_CONVERTER_UMI_DIR=C:\path\to\Umi-OCR
# EBOOK_CONVERTER_UMI_COMMAND=C:\path\to\Umi-OCR\Umi-OCR.exe
# EBOOK_CONVERTER_UMI_PLUGIN_DIR=C:\path\to\Umi-OCR\UmiOCR-data\plugins\win7_x64_PaddleOCR-json
# EBOOK_CONVERTER_UMI_PADDLE_EXE=C:\path\to\PaddleOCR-json.exe
# EBOOK_CONVERTER_UMI_PADDLE_MODULE=C:\path\to\PPOCR_api.py

# Optional Python-native OCR fallback for image/screenshot workflows.
# Install with: python -m pip install -r requirements-rapidocr.txt
# Then pass --ocr-provider rapidocr when you want this backend explicitly.
# EBOOK_CONVERTER_OCR_PROVIDER=rapidocr
# Optional CnOCR comparison provider for Chinese/English image OCR experiments.
# Install with: python -m pip install -r requirements-cnocr.txt
# EBOOK_CONVERTER_CNOCR_REC_MODEL_NAME=ch_PP-OCRv5
# EBOOK_CONVERTER_CNOCR_DET_MODEL_NAME=ch_PP-OCRv5_det
# EBOOK_CONVERTER_CNOCR_CONTEXT=cpu

# Optional pdf-craft scanned-book backend.
# Install with: python -m pip install -r requirements-pdfcraft.txt
# Real conversion also needs Poppler and local DeepSeek OCR model/GPU setup.
# PDFCRAFT_OCR_SIZE=base
# Use --pdfcraft-allow-download explicitly when you want pdf-craft to download models.

# Optional local VLM/PaddleOCR-VL configuration for layout-heavy images.
# Leave unset unless you installed these heavy backends.
# EBOOK_CONVERTER_VLM_PYTHON=C:\path\to\python.exe
# EBOOK_CONVERTER_PADDLEOCR_COMMAND=paddleocr
# PIX2TEXT_COMMAND="python scripts\pix2text_image_to_md.py --input {input} --output {output}"
# PIX2TEXT_LANGUAGES=en,ch_sim
# PIX2TEXT_DEVICE=cpu
# SURYA_COMMAND="python scripts\surya_image_to_md.py --input {input} --output {output}"
# SURYA_OCR_COMMAND=surya_ocr
# SURYA_LAYOUT_COMMAND=surya_layout
# SURYA_TABLE_COMMAND=surya_table

# Optional GOT-OCR 2.0 explicit image OCR experiment backend.
# Upstream setup needs a separate CUDA/torch/flash-attn environment.
# GOT_OCR_SCRIPT=C:\path\to\GOT\demo\run_ocr_2.0.py
# GOT_OCR_CROP_SCRIPT=C:\path\to\GOT\demo\run_ocr_2.0_crop.py
# GOT_OCR_MODEL=C:\path\to\GOT_weights
# GOT_OCR_PYTHON=C:\path\to\got-env\python.exe
# GOT_OCR_TYPE=format
# GOT_OCR_TIMEOUT=0

# Optional DeepSeek-OCR explicit VLM OCR experiment backend.
# Use a separate CUDA/torch/transformers environment; do not install by default.
# DEEPSEEK_OCR_PYTHON=C:\path\to\deepseek-ocr-env\python.exe
# DEEPSEEK_OCR_MODEL=C:\path\to\DeepSeek-OCR
# DEEPSEEK_OCR_PROMPT_MODE=markdown
# DEEPSEEK_OCR_DEVICE=auto
# DEEPSEEK_OCR_ATTENTION=auto
# DEEPSEEK_OCR_TIMEOUT=0

# PADDLEOCR_VL_COMMAND="python scripts\paddleocr_vl_image_to_md.py --input {input} --output {output}"
# QWEN_VL_MODEL=Qwen/Qwen2.5-VL-3B-Instruct

# Optional olmOCR explicit VLM OCR benchmark backend.
# Install with: python -m pip install -r requirements-olmocr.txt
# Local GPU inference is heavy; remote/self-hosted vLLM is usually cleaner.
# EBOOK_CONVERTER_OLMOCR_COMMAND=olmocr
# EBOOK_CONVERTER_OLMOCR_SERVER=http://remote-server:8000/v1
# EBOOK_CONVERTER_OLMOCR_MODEL=allenai/olmOCR-2-7B-1025-FP8
# EBOOK_CONVERTER_OLMOCR_API_KEY_ENV=OLMOCR_API_KEY
# EBOOK_CONVERTER_OLMOCR_WORKERS=1
# EBOOK_CONVERTER_OLMOCR_MAX_CONCURRENT_REQUESTS=2
# EBOOK_CONVERTER_OLMOCR_PAGES_PER_GROUP=4
# EBOOK_CONVERTER_OLMOCR_TIMEOUT=0

# Optional Apache Tika inspect backend for broad MIME/metadata/text-sample
# inspection. It is not a main conversion route and is only called when
# inspect_document is invoked with use_tika=true or for unsupported files.
# EBOOK_CONVERTER_TIKA_SERVER_URL=http://127.0.0.1:9998
# EBOOK_CONVERTER_TIKA_COMMAND="python path\to\tika_wrapper.py {input}"

# Optional GROBID academic PDF/TEI inspect backend. Leave unset unless you run
# a local or remote GROBID Server explicitly.
# EBOOK_CONVERTER_GROBID_SERVER_URL=http://127.0.0.1:8070

# Optional online model provider variables planned for future provider support.
# Keep keys in the environment, not in repository files.
# EBOOK_CONVERTER_ONLINE_PROVIDERS_CONFIG=config\online_providers.local.json
# EBOOK_CONVERTER_ONLINE_MODELS_CONFIG=config\online_models.local.json
# VLM_API_KEY=
# OCR_LAYOUT_API_KEY=
# TEXT_LLM_API_KEY=
# TABLE_LLM_API_KEY=
# EMBEDDING_API_KEY=
