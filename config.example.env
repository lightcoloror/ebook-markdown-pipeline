# Graphic-Text Material Converter example environment.
# Copy this file to .env or load selected variables in your shell.
# Do not commit real API tokens or machine-specific private paths.

# Optional HTTP/API settings. The default local Web/API port is defined in
# config/http.env; use these only when you intentionally override it.
# EBOOK_CONVERTER_HTTP_HOST=127.0.0.1
# EBOOK_CONVERTER_HTTP_PORT=9241
# EBOOK_CONVERTER_DOCKER_HTTP_HOST=0.0.0.0
# EBOOK_CONVERTER_API_TOKEN=replace-with-a-local-token

# Optional local tool/model cache directory.
# If unset, wrappers use a user-level cache or the repository-adjacent tools/
# directory when appropriate.
# EBOOK_CONVERTER_TOOL_CACHE=C:\path\to\ebook-converter-tools

# Optional Umi-OCR configuration for scanned PDFs and images.
# Set the root directory if your Umi-OCR package contains Umi-OCR.exe and
# UmiOCR-data\plugins\win7_x64_PaddleOCR-json.
# EBOOK_CONVERTER_UMI_DIR=C:\path\to\Umi-OCR
# EBOOK_CONVERTER_UMI_COMMAND=C:\path\to\Umi-OCR\Umi-OCR.exe
# EBOOK_CONVERTER_UMI_PLUGIN_DIR=C:\path\to\Umi-OCR\UmiOCR-data\plugins\win7_x64_PaddleOCR-json
# EBOOK_CONVERTER_UMI_PADDLE_EXE=C:\path\to\PaddleOCR-json.exe
# EBOOK_CONVERTER_UMI_PADDLE_MODULE=C:\path\to\PPOCR_api.py

# Optional local VLM/PaddleOCR-VL configuration for layout-heavy images.
# Leave unset unless you installed these heavy backends.
# EBOOK_CONVERTER_VLM_PYTHON=C:\path\to\python.exe
# EBOOK_CONVERTER_PADDLEOCR_COMMAND=paddleocr
# PADDLEOCR_VL_COMMAND="python scripts\paddleocr_vl_image_to_md.py --input {input} --output {output}"
# QWEN_VL_MODEL=Qwen/Qwen2.5-VL-3B-Instruct

# Optional online model provider variables planned for future provider support.
# Keep keys in the environment, not in repository files.
# VLM_API_KEY=
# TEXT_LLM_API_KEY=
