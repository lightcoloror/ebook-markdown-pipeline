# Single source of truth for the shared local MinerU API.
# Port 8000 passed the local port record, live listener, excluded-range, and
# real 127.0.0.1 bind checks on 2026-07-13.
EBOOK_CONVERTER_MINERU_API_SCHEME=http
EBOOK_CONVERTER_MINERU_API_HOST=127.0.0.1
EBOOK_CONVERTER_MINERU_API_PORT=8000
EBOOK_CONVERTER_MINERU_API_COMMAND=mineru-api
EBOOK_CONVERTER_MINERU_API_STATE_ROOT=../.local/mineru-api
