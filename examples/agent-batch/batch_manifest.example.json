{
  "defaults": {
    "output": ".\\agent-batch-output",
    "recursive": true,
    "include_hidden": false,
    "output_format": "markdown",
    "pdf_pipeline_mode": "auto",
    "pdf_tool_idle_timeout": 900,
    "pdf_tool_finalize_timeout": 300,
    "docling_timeout": 45,
    "docling_fallback_to_pandoc": true
  },
  "jobs": [
    {
      "id": "ebooks-folder",
      "input": ".\\sample-materials\\books",
      "intent": "convert"
    },
    {
      "id": "find-keyword-in-pdfs",
      "input": ".\\sample-materials\\documents",
      "output": ".\\agent-batch-output\\location-index",
      "intent": "locate",
      "query": "合同金额",
      "ocr": "auto"
    },
    {
      "id": "screenshots-to-markdown",
      "input": ".\\sample-materials\\screenshots",
      "output": ".\\agent-batch-output\\screenshots",
      "intent": "rebuild",
      "ocr": "auto"
    },
    {
      "id": "web-archive-visual-check",
      "input": ".\\sample-materials\\web-archives\\example-archive",
      "output": ".\\agent-batch-output\\web-archives",
      "intent": "auto"
    }
  ]
}
